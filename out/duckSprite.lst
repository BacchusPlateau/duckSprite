   800 				; =====================================================================
   801 				; fightAttract
   802 				; Call this every frame in your stop loop to prevent attract mode
   803 				; from desaturating your colors
   804 				; ON ENTRY: nothing
   805 				; ON EXIT:  attract mode defeated for this frame
   806 				;======================================================================
   807 337D			        .proc fightAttract
   808
   809 				        ; defeat attract mode and set colors
   810 337D A9 00 85 4D		        mva #0    ATRACT
   811 3381 A9 FF 85 4E		        mva #$FF  ATRMSK
   812
   813 3385 60			        rts
   814 				        .endp
   815
   816 				; =====================================================================
   817 				; Clear the screen
   818
   819 3386			        .proc clearScreen
   820
   821 				; initialize pointer from SAVMSC
   822 3386 A5 58		        lda SAVMSC
   823 3388 85 85		        sta scrptr_lo
   824 338A A5 59		        lda SAVMSC+1
   825 338C 85 86		        sta scrptr_hi
   826
   827 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
   828 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
   829 				; because Y equals zero — exiting the inner loop into the outer loop.
   830
   831 338E A2 1E		        ldx #30             ; X = 30 pages to clear
   832 3390 A0 00		        ldy #0              ; Y = byte index within page
   833
   834 3392			clearpage:
   835 3392 A9 00		        lda #$00
   836 3394 91 85		        sta (scrptr_lo),y   ; write $00
   837 3396 C8			        iny                 ; next byte
   838 3397 D0 F9		        bne clearpage       ; inner loop — 256 bytes
   839
   840 3399 E6 86		        inc scrptr_hi       ; advance to next page
   841 339B CA			        dex                 ; X = X - 1
   842 339C D0 F4		        bne clearpage       ; outer loop — 30 pages
   843
   844 339E 60			        rts
   845 				        .endp
   846
   847
   848 				; =====================================================================
   849 				; Open Graphics Mode 8
   850
   851 339F			        .proc openGR8
   852
   853 				; =====================================================================
   854 				; STEP 1: Close IOCB6
   855 				; Good practice to close before opening — ensures clean state.
   856 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
   857 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
   858 				; ON EXIT:  IOCB6 is closed and ready to be reopened
   859 				; =====================================================================
   860 339F A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   861 33A1 A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
   862 33A3 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
   863 33A6 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
   864
   865 				; =====================================================================
   866 				; STEP 2: Open Graphics Mode 8
   867 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
   868 				; CIO sets up the display list, allocates screen RAM, configures
   869 				; ANTIC — everything needed for graphics mode automatically.
   870 				; ON ENTRY: nothing required
   871 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
   872 				; =====================================================================
   873
   874
   875 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 8
   876 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
   877 				;   pixel data directly to screen RAM.
   878 				;   GR.8:   320 pixels wide × 192 tall   1 bit per pixel     2 colors
   879 				;   GR.8:   40 bytes × 192 rows = 7,680 bytes
   880 				;   GR.8:   320 pixels ÷ 8 pixels per byte = 40 bytes per row
   881 				;   GR.8 byte:  P P P P P P P P
   882 				;               | | | | | | | |
   883 				;               7 6 5 4 3 2 1 0   (8 pixels, 1 bit each, on or off)
   884
   885 33A9 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   886 33AB A9 03		        lda #$03                    ; A = $03        (OPEN command)
   887 33AD 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
   888 33B0 A9 05		        lda #<scrname               ; A = low byte of "S:" string address
   889 33B2 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
   890 33B5 A9 36		        lda #>scrname               ; A = high byte of "S:" string address
   891 33B7 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
   892 33BA A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
   893 33BC 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
   894 33BF A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   895 33C1 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   896 33C4 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   897
   898 				; Step 3: Setup color registers
   899 				; change COLPF1 to change pixel color
   900
   901 33C7 A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
   902 33CC A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
   903 33D1 A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
   904
   905 33D6 60			        rts
   906 				        .endp
   907
   908 				;=========================================================================================
   909 				; draw a line using Bresenham's algorithm
   910
   911 33D7			        .proc drawLine
   912
   913 				        ; first step, compute:
   914 				        ; dx = x2 - x1    (16-bit subtraction)
   915 				        ; dy = y2 - y1    (8-bit subtraction)
   916
   917 33D7 A5 92		        lda y2          ; A = Y2
   918 33D9 38			        sec             ; set carry
   919 33DA E5 8F		        sbc y1          ; A = A - Y1
   920 33DC 85 95		        sta dy          ; dy = A
   921
   922 33DE A5 90		        lda x2          ; A = x2 (low byte)
   923 33E0 38			        sec             ; set carry
   924 33E1 E5 8D		        sbc x1          ; A = A - X1 (low byte)
   925 33E3 85 93		        sta dx_lo       ; save low byte, but do not re-set carry
   926
   927 33E5 A5 91		        lda x2_hi       ; A = X2 (high byte)
   928 33E7 E5 8E		        sbc x1_hi       ; A = A - X1 (high byte)
   929 33E9 85 94		        sta dx_hi       ; save high byte
   930
   931 				        ; check for vertical line (dx = 0)
   932 33EB A5 93		        lda dx_lo
   933 33ED 05 94		        ora dx_hi       ; OR low and high bytes together
   934 33EF D0 33		        bne not_vertical ; if result != 0, not vertical
   935
   936 				        ; handle vertical line
   937 				        ; initialize position first!
   938 33F1 A5 8D		        lda x1
   939 33F3 85 80		        sta plotX_lo
   940 33F5 A5 8E		        lda x1_hi
   941 33F7 85 81		        sta plotX_hi
   942 33F9 A5 8F		        lda y1
   943 33FB 85 82		        sta plotY
   944
   945 				        ; just loop Y from y1 to y2
   946 33FD			vertical_loop:
   947 33FD A5 80		        lda plotX_lo    ; save plotX before plotPoint destroys it
   948 33FF 48			        pha
   949 3400 A5 81		        lda plotX_hi
   950 3402 48			        pha
   951 				        
   952 3403 20 8B 35		        jsr plotPoint
   953 				        
   954 3406 68			        pla             ; restore plotX
   955 3407 85 81		        sta plotX_hi
   956 3409 68			        pla
   957 340A 85 80		        sta plotX_lo
   958 				        
   959 340C E6 82		        inc plotY
   960 340E A5 82		        lda plotY
   961 3410 C5 92		        cmp y2
   962 3412 D0 E9		        bne vertical_loop
   963 				        
   964 				        ; plot final point
   965 3414 A5 80		        lda plotX_lo
   966 3416 48			        pha
   967 3417 A5 81		        lda plotX_hi
   968 3419 48			        pha
   969 341A 20 8B 35		        jsr plotPoint
   970 341D 68			        pla
   971 341E 85 81		        sta plotX_hi
   972 3420 68			        pla
   973 3421 85 80		        sta plotX_lo
   974 				        
   975 3423 60			        rts
   976
   977 3424			not_vertical:
   978 				        ; continue with normal Bresenham...
   979
   980 				        ; initialize current position to start point
   981 3424 A5 8D		        lda x1          ; A = X1
   982 3426 85 80		        sta plotX_lo    ; plotX_lo = A
   983 3428 A5 8E		        lda x1_hi       ; A = X1_hi
   984 342A 85 81		        sta plotX_hi    ; plotX_hi = A
   985 342C A5 8F		        lda y1          ; A = Y1
   986 342E 85 82		        sta plotY       ; plotY = A
   987
   988 				        ; initialize error to 0
   989 3430 A9 00 85 96		        mva #0 err_lo           ; err_lo = 0
   990 3434 A9 00 85 97		        mva #0 err_hi           ; err_hi = 0
   991
   992 3438			lineloop:
   993 				        ; save plotX before plotPoint destroys it
   994 3438 A5 80		        lda plotX_lo
   995 343A 48			        pha
   996 343B A5 81		        lda plotX_hi
   997 343D 48			        pha
   998
   999 343E 20 8B 35		        jsr plotPoint
  1000
  1001 				        ; restore plotX after plotPoint
  1002 3441 68			        pla
  1003 3442 85 81		        sta plotX_hi
  1004 3444 68			        pla
  1005 3445 85 80		        sta plotX_lo
  1006
  1007 				; add dy to error accumulator (16-bit + 8-bit addition)
  1008 3447 A5 96		        lda err_lo              ; A = err_lo
  1009 3449 18			        clc                     ; clear carry
  1010 344A 65 95		        adc dy                  ; A += dy
  1011 344C 85 96		        sta err_lo              ; err_lo = A
  1012 344E A5 97		        lda err_hi              ; A = err_hi
  1013 3450 69 00		        adc #0                  ; propagate carry trick. if the carry was set it gets added to the high byte
  1014 3452 85 97		        sta err_hi              ; err_hi = A
  1015
  1016 				        ; check if error * 2 >= dx
  1017 				        ; compute error + error (16-bit)
  1018 3454 A5 96		        lda err_lo              ; A = err_lo
  1019 3456 18			        clc                     ; clear carry
  1020 3457 65 96		        adc err_lo              ; A += err_lo (err_lo * 2)
  1021 3459 85 83		        sta temp_lo             ; temp_lo = A
  1022 345B A5 97		        lda err_hi              ; A = err_hi
  1023 345D 65 97		        adc err_hi              ; A += err_hi ((err_hi * 2) + carry)
  1024 345F 85 84		        sta temp_hi             ; temp_hi = A
  1025
  1026 				        ; compare temp (error*2) to dx
  1027 				        ; 16-bit comparison: check high byte first, then low byte
  1028 3461 A5 84		        lda temp_hi     ; A = temp_hi
  1029 3463 C5 94		        cmp dx_hi       ; Does temp_hi == dx_hi? 
  1030 3465 90 17		        bcc skip_y      ; temp_hi < dx_hi, no Y step needed (branch if carry is clear)
  1031 3467 D0 06		        bne do_y_step   ; temp_hi > dx_hi, Y step needed (branch if not equal)
  1032 3469 A5 83		        lda temp_lo     ; A = temp_lo (high bytes equal, check low bytes (if we got here, high bytes are equal))
  1033 346B C5 93		        cmp dx_lo       ; Does temp_lo == dx_lo?
  1034 346D 90 0F		        bcc skip_y      ; temp_lo < dx_lo, no Y step needed
  1035
  1036 346F			do_y_step:
  1037 346F E6 82		        inc plotY       ; y = y + 1
  1038
  1039 				        ; error = error - dx (16-bit subtraction)
  1040 3471 A5 96		        lda err_lo      ; A = err_lo
  1041 3473 38			        sec             ; set the carry
  1042 3474 E5 93		        sbc dx_lo       ; A -= dx_lo
  1043 3476 85 96		        sta err_lo      ; err_lo = A
  1044 3478 A5 97		        lda err_hi      ; A = err_hi
  1045 347A E5 94		        sbc dx_hi       ; A -= dex_hi
  1046 347C 85 97		        sta err_hi      ; err_hi = A
  1047
  1048 347E			skip_y:
  1049 				        ; advance x (16-bit increment)
  1050 347E E6 80		        inc plotX_lo            ; plotX_lo++
  1051 3480 D0 02		        bne lineloop_check      ; if no overflow, check if done 
  1052 				                                ; if plotX_lo != 0 JUMP FORWARD to lineloop_check
  1053 3482 E6 81		        inc plotX_hi            ; handle overflow from low to high byte
  1054 				                                ; only reaches here if plotX_lo overflowed to 0
  1055
  1056 3484			lineloop_check:
  1057 				        ; are we done? compare plotX to x2
  1058 3484 A5 80		        lda plotX_lo            ; A = plotX_lo
  1059 3486 C5 90		        cmp x2                  ; test: A = X2 ?
  1060 3488 D0 AE		        bne lineloop            ; not done, keep going
  1061 				                                ; if plotX_lo != x2 JUMP BACK to lineloop
  1062 348A A5 81		        lda plotX_hi            ; A = plotX_hi
  1063 348C C5 91		        cmp x2_hi               ; test: A = x2_hi ?
  1064 348E D0 A8		        bne lineloop            ; not done, keep going
  1065 				                                ; if plotX_hi != x2_hi JUMP BACK to lineloop
  1066 				                                ; if both match we fall through - done!
  1067
  1068 				        
  1069
  1070 3490 60			        rts
  1071 				        .endp
  1072
  1073
  1074 				;=========================================================================================
  1075 				; print a string
  1076 				; Assumptions
  1077 				; strptr_lo = low address of the string
  1078 				; strptr_hi = high address of the string
  1079 				;       together we have a 16-bit address of the string
  1080
  1081 				; Y = index of current character to process, starts at 0
  1082 				; example calling code:
  1083 				;       mva #1 csrhinh                  ; hide the cursor
  1084 				;        mva #6 rowcrs                   ; set output row
  1085 				;        mva #10 colcrs                  ; set output column
  1086 				;        
  1087 				;        mva #<string1 strptr_lo         ; low byte of string1 address
  1088 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
  1089 				;        jsr print_string                ; print the string
  1090 				;
  1091 				;========= don't forget you'll need data
  1092 				;       .local string1
  1093 				;        .byte 'HELLO FROM STRING ONE!',0
  1094 				;        .endl
  1095
  1096 				;======================================================================
  1097 3491			        .proc print_string
  1098 3491 A0 00		        ldy #0
  1099 3493			loop:
  1100 3493 B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
  1101 3495 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
  1102 3497 F0 0D		        beq exit                        ; if true, branch to exit
  1103 3499 98			        tya                             ; A = Y
  1104 349A 48			        pha                             ; push A onto the stack
  1105 349B B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
  1106 349D 20 AA 34		        jsr putchar                     ; call putchar to write a character out
  1107 34A0 68			        pla                             ; A = pop stack
  1108 34A1 A8			        tay                             ; Y = A
  1109 34A2 C8			        iny                             ; Y = Y + 1
  1110 34A3 4C 93 34		        jmp loop                        ; GOTO loop
  1111 34A6			exit:
  1112 34A6 60			        rts                             ; exit subroutine
  1113 				        .endp
  1114
  1115 34A7			stop:
  1116 34A7 4C A7 34		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
  1117 				;======================================================================
  1118
  1119 				; print a character
  1120 				; Assumptions
  1121 				; 1. the character is in register A
  1122 				; 2. the character has been converted to ATASCII
  1123 				; 3. before calling, save values of X and Y registers
  1124
  1125 34AA			        .proc putchar
  1126 34AA AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
  1127 34AB AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
  1128 34AE 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
  1129 34AF AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
  1130 34B2 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
  1131 34B3 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
  1132 34B4 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
  1133 				        .endp           ; end of putchar procedure
  1134
  1135 				;========================================================================================
  1136 				;       print a 16-bit decimal
  1137 				;       ON ENTRY: p16_val_lo/p16_val_hi contains the value to print
  1138
  1139 34B5			        .proc printBigDecimal
  1140
  1141 				        ; Ten thousands place
  1142 34B5 A9 00 85 A5		        mva #0 p16_digit
  1143
  1144 34B9			tenthousands:
  1145 				        ; is p16_val >= 10000?
  1146 34B9 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1147 34BB C9 27		        cmp #$27                ; 10,000 base 10 is $2710, that's why we're comparing $27 here, the hi byte
  1148 34BD 90 1A		        bcc doneTenThousands    ; < 10000, done
  1149 34BF D0 06		        bne do_subTenThousands  ; > 10000, subtract
  1150 34C1 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1151 34C3 C9 10		        cmp #$10                ; now we're comparing the low byte of the literal $2710 hex value
  1152 34C5 90 12		        bcc doneTenThousands    ; = exactly check low byte
  1153
  1154 34C7			do_subTenThousands:
  1155 				        ; subtract 10000 (16-bit)
  1156 34C7 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1157 34C9 38			        sec                     ; set the carry
  1158 34CA E9 10		        sbc #$10                ; A -= $10 (we are subtracting the low byte first. looks weird because it's a literal)
  1159 34CC 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1160 34CE A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1161 34D0 E9 27		        sbc #$27                ; A -= $27 (we are subtracting the high byte of $2710 or 10,000 base 10)
  1162 34D2 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1163 34D4 E6 A5		        inc p16_digit           ; p16_digit++
  1164 34D6 4C B9 34		        jmp tenthousands        ; keep going
  1165
  1166 34D9			doneTenThousands:
  1167 				        ; print the digit
  1168 34D9 A5 A5		        lda p16_digit
  1169 34DB 18			        clc
  1170 34DC 69 30		        adc #offset_to_char
  1171 34DE 20 AA 34		        jsr putchar
  1172
  1173 				        ; Thousands
  1174 34E1 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1175 34E5			thousands:
  1176 				        ; is p16_val >= 1000?
  1177 34E5 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1178 34E7 C9 03		        cmp #$3                 ; 1000 base 10 is $03E8, that's why we're comparing $3 here, the hi byte
  1179 34E9 90 1A		        bcc doneThousands       ; < 1000, done
  1180 34EB D0 06		        bne do_subThousands     ; > 1000, subtract
  1181 34ED A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1182 34EF C9 E8		        cmp #$E8                ; now we're comparing the low byte of the literal $03E8 hex value
  1183 34F1 90 12		        bcc doneThousands       ; = exactly check low byte
  1184
  1185 34F3			do_subThousands:
  1186 				        ; subtract 1000 (16-bit)
  1187 34F3 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1188 34F5 38			        sec                     ; set the carry
  1189 34F6 E9 E8		        sbc #$E8                ; A -= $E8 (we are subtracting the low byte first. looks weird because it's a literal)
  1190 34F8 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1191 34FA A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1192 34FC E9 03		        sbc #$3                 ; A -= $3 (we are subtracting the high byte of $03E8 or 1000 base 10)
  1193 34FE 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1194 3500 E6 A5		        inc p16_digit           ; p16_digit++
  1195 3502 4C E5 34		        jmp thousands           ; keep going
  1196
  1197 3505			doneThousands:
  1198 				        ; print the digit
  1199 3505 A5 A5		        lda p16_digit
  1200 3507 18			        clc
  1201 3508 69 30		        adc #offset_to_char
  1202 350A 20 AA 34		        jsr putchar      
  1203
  1204
  1205 				        ; Hundreds
  1206 350D A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1207 3511			hundreds:
  1208 				        ; is p16_val >= 100?
  1209 3511 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1210 3513 C9 00		        cmp #$0                
  1211 3515 90 1A		        bcc doneHundreds     
  1212 3517 D0 06		        bne do_subHundreds     
  1213 3519 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1214 351B C9 64		        cmp #$64              
  1215 351D 90 12		        bcc doneHundreds        ; = exactly check low byte
  1216
  1217 351F			do_subHundreds:
  1218 				        ; subtract 100 (16-bit)
  1219 351F A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1220 3521 38			        sec                     ; set the carry
  1221 3522 E9 64		        sbc #$64                ;  (we are subtracting the low byte first. looks weird because it's a literal)
  1222 3524 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1223 3526 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1224 3528 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
  1225 352A 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1226 352C E6 A5		        inc p16_digit           ; p16_digit++
  1227 352E 4C 11 35		        jmp hundreds           ; keep going
  1228
  1229 3531			doneHundreds:
  1230 				        ; print the digit
  1231 3531 A5 A5		        lda p16_digit
  1232 3533 18			        clc
  1233 3534 69 30		        adc #offset_to_char
  1234 3536 20 AA 34		        jsr putchar   
  1235
  1236 				        ; Tens
  1237 3539 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1238 353D			tens:
  1239 				        ; is p16_val >= 10?
  1240 353D A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1241 353F C9 00		        cmp #$0                
  1242 3541 90 1A		        bcc doneTens     
  1243 3543 D0 06		        bne do_subTens     
  1244 3545 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1245 3547 C9 0A		        cmp #$0A              
  1246 3549 90 12		        bcc doneTens        ; = exactly check low byte
  1247
  1248 354B			do_subTens:
  1249 				        ; subtract 100 (16-bit)
  1250 354B A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1251 354D 38			        sec                     ; set the carry
  1252 354E E9 0A		        sbc #$0A                ;  (we are subtracting the low byte first. looks weird because it's a literal)
  1253 3550 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1254 3552 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1255 3554 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
  1256 3556 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1257 3558 E6 A5		        inc p16_digit           ; p16_digit++
  1258 355A 4C 3D 35		        jmp tens           ; keep going
  1259
  1260 355D			doneTens:
  1261 				        ; print the digit
  1262 355D A5 A5		        lda p16_digit
  1263 355F 18			        clc
  1264 3560 69 30		        adc #offset_to_char
  1265 3562 20 AA 34		        jsr putchar
  1266
  1267 				        ; ones are whatever is left in p16_val_lo
  1268 3565 A5 A3		        lda p16_val_lo
  1269 3567 18			        clc
  1270 3568 69 30		        adc #offset_to_char
  1271 356A 20 AA 34		        jsr putchar
  1272
  1273 356D 60			        rts
  1274 				        .endp
  1275
  1276
  1277 				;========================================================================================
  1278 				        ; print both digits in base 10, from left to right
  1279 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
  1280 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
  1281 				        ; Assumtions: A contains the hex value of the number to print
  1282
  1283 356E			        .proc printDecimal
  1284 356E A2 00		        ldx #0
  1285 3570			checkCount:
  1286 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
  1287 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
  1288 3570 C9 0A		        cmp #10             ; Does A = 10?
  1289 3572 90 07		        bcc doneCounting    ; branch if carry is cleared
  1290 3574 38			        sec                 ; set carry
  1291 3575 E9 0A		        sbc #10             ; A = A - 10
  1292 3577 E8			        inx                 ; X = X + 1
  1293 3578 4C 70 35		        jmp checkCount
  1294
  1295 357B			doneCounting:   
  1296 357B 48			        pha                 ; push(A) (push A onto the stack)
  1297 357C 8A			        txa                 ; A = X
  1298 357D 18			        clc
  1299 357E 69 30		        adc #offset_to_char
  1300 3580 20 AA 34		        jsr putchar
  1301
  1302 3583 68			        pla                 ; A = pop() (pop the next value off the stack)
  1303 3584 18			        clc 
  1304 3585 69 30		        adc #offset_to_char
  1305 3587 20 AA 34		        jsr putchar
  1306 358A 60			        rts
  1307 				        .endp
  1308 				;==================================================================================================
  1309
  1310 				; plot a point (x,y)
  1311 				; Step 1: Find which ROW we're on
  1312 				;        plotY × 40 = how many bytes to skip to reach our row
  1313 				;        (each row is 40 bytes wide)
  1314 				;        2^3 + 2^2
  1315 				; Step 2: Find which BYTE within that row
  1316 				;        plotX ÷ 8 = which byte contains our pixel
  1317 				;        (each byte holds 8 pixels)
  1318 				;
  1319 				; Step 3: Add them together
  1320 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
  1321 				;
  1322 				; Step 4: Add SAVMSC
  1323 				;        SAVMSC + offset = actual address in memory of our byte
  1324 				;
  1325 				; Step 5: Find which BIT within that byte
  1326 				;        7 - (plotX mod 8) = which bit is our pixel
  1327 				;
  1328 				; Step 6: Set that bit
  1329 				;        read the byte
  1330 				;        OR with our bit mask
  1331 				;        write the byte back
  1332 				;
  1333 358B			        .proc plotPoint
  1334
  1335 				        ; see multiplyingYby40.txt for full breakdown with an example!
  1336
  1337 				        ; defeat attract mode on every plot
  1338 358B A9 00 85 4D		        mva #0    ATRACT
  1339 358F A9 FF 85 4E		        mva #$FF  ATRMSK
  1340
  1341 				        ; Step 1: Find which ROW we're on
  1342 3593 A5 82		        lda plotY
  1343 3595 85 83		        sta temp_lo         ; temp = plotY
  1344 3597 A9 00		        lda #0
  1345 3599 85 84		        sta temp_hi         ; high byte starts at 0
  1346
  1347 				        ; × 2
  1348 359B 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
  1349 359D 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
  1350
  1351 				        ; × 4
  1352 359F 06 83		        asl temp_lo
  1353 35A1 26 84		        rol temp_hi
  1354
  1355 				        ; × 8  ← save this!
  1356 35A3 06 83		        asl temp_lo
  1357 35A5 26 84		        rol temp_hi
  1358 35A7 A5 83		        lda temp_lo
  1359 35A9 85 87		        sta save_lo
  1360 35AB A5 84		        lda temp_hi
  1361 35AD 85 88		        sta save_hi
  1362
  1363 				        ; × 16
  1364 35AF 06 83		        asl temp_lo
  1365 35B1 26 84		        rol temp_hi
  1366
  1367 				        ; × 32
  1368 35B3 06 83		        asl temp_lo
  1369 35B5 26 84		        rol temp_hi
  1370
  1371 35B7 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
  1372 35B9 18			        clc                 ; clear carry
  1373 35BA 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
  1374 35BC 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
  1375
  1376 35BE A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
  1377 35C0 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
  1378 35C2 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
  1379 				        ; we now have the offset to our target row in temp_lo and temp_hi
  1380
  1381 				        ; calculate which bit 
  1382 35C4 A5 80		        lda plotX_lo
  1383 35C6 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
  1384 35C8 85 89		        sta bitpos          ; save for Step 5
  1385
  1386 				        ; Step 2: find offset from start of row to our pixel
  1387 				        ; plotX ÷ 8 using 16-bit right shift
  1388 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
  1389 				        ; ON EXIT:  A contains column byte offset (0-39)
  1390 35CA 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
  1391 35CC 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
  1392
  1393 35CE 46 81		        lsr plotX_hi        ; shift again
  1394 35D0 66 80		        ror plotX_lo
  1395
  1396 35D2 46 81		        lsr plotX_hi        ; shift again
  1397 35D4 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
  1398
  1399 				        ; Step 3: add results from step 1 and 2 together
  1400 35D6 A5 83		        lda temp_lo
  1401 35D8 18			        clc
  1402 35D9 65 80		        adc plotX_lo
  1403 35DB 85 83		        sta temp_lo
  1404
  1405 35DD A5 84		        lda temp_hi
  1406 35DF 69 00		        adc #0
  1407 35E1 85 84		        sta temp_hi
  1408 				        ; temp now contains total byte offset from SAVMSC
  1409
  1410 				        ; Step 4: Add SAVMSC Base Address
  1411 35E3 A5 83		        lda temp_lo
  1412 35E5 18			        clc
  1413 35E6 65 58		        adc SAVMSC
  1414 35E8 85 85		        sta scrptr_lo
  1415
  1416 35EA A5 84		        lda temp_hi
  1417 35EC 65 59		        adc SAVMSC+1
  1418 35EE 85 86		        sta scrptr_hi
  1419
  1420 				        ; Step 5: find which bit to turn on
  1421 				        ; algo:  bit position = 7 - (plotX mod 8)
  1422 				        ; Step 5: find which bit to turn on
  1423 35F0 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
  1424 35F2 A6 89		        ldx bitpos          ; X = number of times to shift right
  1425 35F4 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
  1426 35F6			shift_loop:
  1427 35F6 4A			        lsr                 ; shift A right one position
  1428 35F7 CA			        dex                 ; X = X - 1
  1429 35F8 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
  1430 35FA			done_shift:
  1431 				                            ; A now contains our bit mask
  1432
  1433 				        ; Step 6: turn on our bit!!
  1434 35FA 85 8A		        sta bitmask             ; save mask
  1435 35FC A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
  1436 35FE B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
  1437 3600 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
  1438 3602 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
  1439
  1440 3604 60			        rts
  1441 				        .endp
  1442
  1443
  1444 				;======================================================================
  1445 				; printArray
  1446 				; Assumptions:
  1447 				;       name of array is Numbers
  1448 				;       x1 is used to hold x while we are printing
  1449
  1450 				; DELETED DUE TO MISSING ZeroPage variable 'numbers'
  1451
  1452
  1453
  1454 				; =====================================================================
  1455 				; DATA
  1456 				; =====================================================================
  1457 3605 53 3A 9B		scrname .byte 'S:',$9B             ; device name string for CIO OPEN
  1458 				                                    ; 'S:' = screen device
  1459 				                                    ; $9B  = ATASCII end-of-line terminator
     3
     4 3608			        org $2000
     5
     6 2000			 .proc main
     7
     8 2000-210F> 20 9F 33	        jsr openGR8
     9 2003 20 18 30		        jsr initPMG
    10
    11 				        ; set the duck's STARTING position BEFORE the first draw —
    12 				        ; loadDuckFrame reads shipY to know where to draw, so it must
    13 				        ; already hold a real value, not whatever garbage zero-page
    14 				        ; happened to have at boot
    15 2006 A9 5A 85 B1		        mva #90 shipX
    16 200A A9 00 85 B2		        mva #0 shipY
    17 200E A9 00 85 B3		        mva #0 walkFrame
    18
    19 				        ; load the STARTING frame (duckShape1) into PM memory —
    20 				        ; point spritePtr at it and let loadDuckFrame do the copy
    21 2012 A9 F0		        lda #<duckShape1
    22 2014 85 A6		        sta spritePtr_lo
    23 2016 A9 20		        lda #>duckShape1
    24 2018 85 A7		        sta spritePtr_hi
    25 201A 20 A8 20		        jsr loadDuckFrame
    26
    27 201D			keepDucking:
    28 201D A5 B1		        lda shipX               ; a = shipX
    29 201F 8D 00 D0		        sta HPOSP0              ; push shipX to Player 0's horizontal position
    30
    31 2022 20 CF 20		        jsr eraseDuckFrame      ; clear the OLD row — must happen before
    32 				                                ; shipY changes below, or we'd erase the
    33 				                                ; NEW position instead of the old one
    34
    35 2025 A9 00 85 83		        mva #0 temp_lo          ; "did we move this step?" flag — reused
    36 				                                ; zero-page var, unused elsewhere here
    37
    38 2029 AD 78 02		        lda STICK0
    39 202C 29 04		        and #%00000100      ; isolate bit 2 (Left)
    40 202E F0 03		        beq isLeft
    41 2030 4C 39 20		        jmp checkRight
    42 2033			isLeft:
    43 2033 C6 B1		        dec shipX
    44 2035 A9 01 85 83		        mva #1 temp_lo
    45
    46 2039			checkRight:
    47 2039 AD 78 02		        lda STICK0
    48 203C 29 08		        and #%00001000      ; isolate bit 3 (Right)
    49 203E F0 03		        beq isRight
    50 2040 4C 49 20		        jmp checkUp
    51 2043			isRight:
    52 2043 E6 B1		        inc shipX
    53 2045 A9 01 85 83		        mva #1 temp_lo
    54
    55 2049			checkUp:
    56 2049 AD 78 02		        lda STICK0
    57 204C 29 01		        and #%00000001      ; isolate bit 0 (Up)
    58 204E F0 03		        beq isUp
    59 2050 4C 59 20		        jmp checkDown
    60 2053			isUp:
    61 2053 C6 B2		        dec shipY
    62 2055 A9 01 85 83		        mva #1 temp_lo
    63
    64 2059			checkDown:
    65 2059 AD 78 02		        lda STICK0
    66 205C 29 02		        and #%00000010      ; isolate bit 1 (Down)
    67 205E F0 03		        beq isDown
    68 2060 4C 69 20		        jmp doneReading
    69 2063			isDown:
    70 2063 E6 B2		        inc shipY
    71 2065 A9 01 85 83		        mva #1 temp_lo
    72
    73 2069			doneReading:
    74 2069 A5 83		        lda temp_lo             ; did ANY direction fire this step?
    75 206B F0 02		        beq noFlip              ; no movement at all -> don't flip
    76 206D E6 B3		        inc walkFrame           ; exactly ONE increment per step,
    77 				                                ; no matter how many axes moved
    78 206F			noFlip:
    79
    80 				        ; --- pick this step's walk-cycle frame ---
    81 				        ; even walkFrame -> duckShape1, odd walkFrame -> duckShape2
    82 				        ; walkFrame now increments once per MOVED STEP, not once per
    83 				        ; axis — so diagonals flip the same as straight movement
    84
    85 206F A5 B3		        lda walkFrame
    86 2071 29 01		        and #%00000001           ; isolate bit 0 (the "is it odd" bit)
    87 2073 F0 0B		        beq useFrame1
    88
    89 2075 A9 00		        lda #<duckShape2
    90 2077 85 A6		        sta spritePtr_lo
    91 2079 A9 21		        lda #>duckShape2
    92 207B 85 A7		        sta spritePtr_hi
    93 207D 4C 88 20		        jmp doLoad
    94
    95 2080			useFrame1:
    96 2080 A9 F0		        lda #<duckShape1
    97 2082 85 A6		        sta spritePtr_lo
    98 2084 A9 20		        lda #>duckShape1
    99 2086 85 A7		        sta spritePtr_hi
   100
   101 2088			doLoad:
   102 2088 20 A8 20		        jsr loadDuckFrame        ; copy whichever table we just pointed at
   103
   104 208B A9 1E		        lda #$1E                 ; TODO: this should be a variable in equates
   105 208D 8D 12 D0		        sta COLPM0                ; color for Player 0
   106
   107 2090 A2 05		        ldx #5                  ; frames to hold before the next step
   108 2092 20 00 32		        jsr waitFrames           ; holds here, refreshing HPOSP0/COLPM0
   109 				                                 ; every frame internally
   110 2095 4C 1D 20		        jmp keepDucking
   111
   112
   113 2098			stop:
   114 2098 20 7D 33		        jsr fightAttract
   115 209B A5 B1		        lda shipX
   116 209D 8D 00 D0		        sta HPOSP0               ; stop loop also needs to refresh,
   117 20A0 A9 1E		        lda #$1E                ; since it's another long-running
   118 20A2 8D 12 D0		        sta COLPM0               ; loop with the same characteristics
   119 20A5 4C 98 20		        jmp stop
   120
   121 				        .endp
