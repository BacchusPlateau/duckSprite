    69 				; =====================================================================
    70 				; CIO (Central I/O) constants
    71 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    72 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    73 				; of memory containing command, device, buffer address, and aux bytes.
    74 				; We use IOCB6 (base address $0360) for graphics.
    75 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    76 				; =====================================================================
    77 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    78 = 0342			ICCOM   = $0342     ; IOCB6 command register
    79 				                    ;   $03 = OPEN   (open a device)
    80 				                    ;   $0C = CLOSE  (close a device)
    81 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    82 				                    ;   for OPEN: points to device name string "S:"
    83 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    84 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    85 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    86 				                    ;   for OPEN: $0C = read/write access mode
    87 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    88 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    89
    90 				; =====================================================================
    91 				; Screen RAM pointer
    92 				; After CIO opens GR.8, the OS stores the address of screen RAM
    93 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    94 				; On our 800XL PAL system screen RAM ends up at $B060.
    95 				; =====================================================================
    96 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    97 				                    ; $59 automatically contains the high byte
    98
    99 				; =====================================================================
   100 				; Attract mode constants
   101 				; The Atari OS has an attract mode that kicks in after inactivity
   102 				; to prevent screen burn-in. It does this by desaturating all colors
   103 				; making everything appear as shades of grey/blue.
   104 				; We must continuously reset these in our main loop to keep colors!
   105 				; =====================================================================
   106 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
   107 				                    ; when it reaches a threshold attract mode activates
   108 				                    ; we keep writing 0 to prevent it from activating
   109 = 004E			ATRMSK  = $4E       ; attract mode color mask
   110 				                    ; OS ANDs all colors with this value
   111 				                    ; $FE strips hue leaving only luminance (grey/blue)
   112 				                    ; $FF = full color (no masking) — what we want
   113
   114 				; =====================================================================
   115 				; Player-Missile Graphics (PMG) constants
   116 				; PMG is dedicated GTIA/ANTIC hardware for moving sprites — completely
   117 				; separate from the GR.8 bitmap screen RAM we've been drawing into.
   118 				; ANTIC reads this memory automatically every frame and GTIA overlays
   119 				; it on top of the playfield, with zero CPU cost for the overlay itself.
   120 				; =====================================================================
   121
   122 = 5000			PMBASE  = $5000     ; start of our PM memory block. MUST be page-aligned
   123 				                    ; (low byte = $00) because ANTIC only stores a HIGH
   124 				                    ; byte pointer to this memory — there's no low byte
   125 				                    ; register, so the low byte is implicitly always $00
   126
   127 				; --- OS shadow registers (same pattern as SDMCTL/SDLSTL we already use) ---
   128 = D407			PMBASE_SHADOW = $D407   ; hardware register: tells ANTIC the HIGH byte
   129 				                        ; of where PM memory starts (PMBASE ÷ 256)
   130 				                        ; NOTE: unlike SDMCTL, there's no safe OS shadow
   131 				                        ; register for this one — we write directly to
   132 				                        ; hardware, similar to how we had to fight
   133 				                        ; attract mode by writing hardware directly
   134
   135 = D01D			GRACTL  = $D01D     ; GTIA register — Graphics Control
   136 				                    ; controls whether players/missiles are displayed
   137 				                    ; at all, and whether collision detection is active
   138 				                    ; bit 0 = enable missile graphics
   139 				                    ; bit 1 = enable player graphics
   140 				                    ; bit 2 = enable latching (collision detection mode)
   141
   142 				; --- Player 0 hardware registers ---
   143 = D000			HPOSP0  = $D000     ; horizontal position of Player 0 (one byte!)
   144 				                    ; THIS is the magic register — changing this one
   145 				                    ; byte instantly moves the sprite left/right with
   146 				                    ; no redraw needed at all, unlike our manual sprite
   147 = D008			SIZEP0  = $D008     ; width of Player 0: 0=normal, 1=double, 3=quad width
   148 = D012			COLPM0  = $D012     ; color of Player 0 (shadow: $02C0)
   149
   150 				; --- DMACTL bit for enabling PM DMA (added to what openGR8 already sets) ---
   151 				; DMACTL is the SAME register as SDMCTL we already use in openGR8 —
   152 				; PM graphics needs an ADDITIONAL bit set on top of what we already
   153 				; configure for the playfield, not a separate register
   154 = 0010			PMG_ENABLE_BIT = %00010000   ; bit 4 of SDMCTL enables single-line
   155 				                            ; resolution PM DMA (we'll OR this into
   156 				                            ; whatever openGR8 already sets)
   157 = 022F			SDMCTL  = $022F     ; OS shadow register for DMA control — CIO already
   158 				                    ; writes the correct playfield bits here when
   159 				                    ; opening a graphics mode; we OR in our PM bit
   160 				                    ; on top of whatever CIO set, rather than guessing                                            
   161
   162
   163 				; --- Corrected per bumbershootsoft.wordpress.com reference ---
   164 = 026F			GPRIOR  = $026F     ; shadow for PRIOR ($D01B) — priority/5-player mode
   165 				                    ; not strictly needed for a single player test,
   166 				                    ; but useful to know about going forward
   167
   168 = 002E			PMG_DMACTL_VALUE = $2E    ; full correct DMACTL value, not just one bit:
   169 				                          ; bits 0-1 = playfield width (2 = normal)
   170 				                          ; bit 2 = missile DMA enable
   171 				                          ; bit 3 = player DMA enable
   172 				                          ; bit 5 = display list DMA enable (needed
   173 				                          ;         for ANY playfield to show at all!)                    
   174
   175 = 00B1			shipX = $B1        ; sprite 0 current X position
   176 = 00B2			shipY = $B2        ; sprite 0 current Y position
   177 = 00B3			walkFrame = $B3    ; increments on ANY movement (either axis) — drives
   178 				                   ; which walk-cycle frame shows, independent of
   179 				                   ; shipX/shipY themselves
   180 				; =====================================================================
   181 				; Joystick input
   182 				; The OS polls the joystick hardware every frame and stores the
   183 				; debounced result here for us — no need to touch the PIA directly.
   184 				; =====================================================================
   185 = 0278			STICK0  = $0278     ; joystick 1 direction bits, ACTIVE LOW (0=pressed):
   186 				                    ; bit 0 = Up, bit 1 = Down, bit 2 = Left, bit 3 = Right
