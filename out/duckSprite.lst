     4 				shipSprite
     5 FFFF> 3000-3607> 00 00	        .byte $00,$00
     6 3002 00 00		        .byte $00,$00
     7 3004 00 00		        .byte $00,$00
     8 3006 01 80		        .byte $01,$80
     9 3008 02 20		        .byte $02,$20
    10 300A 04 10		        .byte $04,$10
    11 300C 3F FC		        .byte $3F,$FC
    12 300E 16 24		        .byte $16,$24
    13 3010 0F F8		        .byte $0F,$F8
    14 3012 03 E0		        .byte $03,$E0
    15 3014 00 00		        .byte $00,$00
    16 3016 00 00		        .byte $00,$00
