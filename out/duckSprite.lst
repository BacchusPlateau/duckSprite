   211 				; Data section
   212 				;===================================================================
   213
   214 				        ; Bit order: bit 7 (leftmost) = screen-left, bit 0 (rightmost) =
   215 				        ; screen-right, same convention as beowulfShape. Row count is
   216 				        ; free — .len duckShape in the load loop above picks up
   217 				        ; whatever you put here, add/remove rows as you like.
   218 20F0			        .local duckShape1
   219 20F0 3C			        .byte %00111100     ; row 0  - crown of head
   220 20F1 74			        .byte %01110100     ; row 1  - head
   221 20F2 7F			        .byte %01111111     ; row 2  - head, eye level
   222 20F3 7E			        .byte %01111110     ; row 3  - beak
   223 20F4 7D			        .byte %01111101     ; row 4  - chin, head narrows
   224 20F5 38			        .byte %00111000     ; row 5  - neck
   225 20F6 38			        .byte %00111000     ; row 6  - neck/body transition
   226 20F7 38			        .byte %00111000     ; row 7  - body widening
   227 20F8 38			        .byte %00111000     ; row 8  - body, max width
   228 20F9 FF			        .byte %11111111     ; row 9  - body, max width
   229 20FA FF			        .byte %11111111     ; row 10 - body
   230 20FB 7E			        .byte %01111110     ; row 11 - body narrowing
   231 20FC 3C			        .byte %00111100     ; row 12 - tail / body bottom
   232 20FD 24			        .byte %00100100     ; row 13 - legs
   233 20FE 64			        .byte %01100100     ; row 14 - legs
   234 20FF 06			        .byte %00000110     ; row 15 - webbed feet
   235 				        .endl
   236
   237 				        ; identical clone of duckShape — edit this one's legs/wing rows
   238 				        ; to create the second walk-cycle pose (frame length can differ
   239 				        ; from duckShape's if you use .len duckShape2 wherever this
   240 				        ; table's row count matters)
   241 2100			        .local duckShape2
   242 2100 3C			        .byte %00111100     ; row 0  - crown of head
   243 2101 74			        .byte %01110100     ; row 1  - head
   244 2102 7F			        .byte %01111111     ; row 2  - head, eye level
   245 2103 7F			        .byte %01111111     ; row 3  - beak
   246 2104 7C			        .byte %01111100     ; row 4  - chin, head narrows
   247 2105 38			        .byte %00111000     ; row 5  - neck
   248 2106 38			        .byte %00111000     ; row 6  - neck/body transition
   249 2107 38			        .byte %00111000     ; row 7  - body widening
   250 2108 38			        .byte %00111000     ; row 8  - body, max width
   251 2109 7E			        .byte %01111110     ; row 9  - body, max width
   252 210A FF			        .byte %11111111     ; row 10 - body
   253 210B 7E			        .byte %01111110     ; row 11 - body narrowing
   254 210C 3C			        .byte %00111100     ; row 12 - tail / body bottom
   255 210D 24			        .byte %00100100     ; row 13 - legs
   256 210E 26			        .byte %00100110     ; row 14 - legs
   257 210F 60			        .byte %01100000     ; row 15 - webbed feet
   258 				        .endl
