   124 				;=========================================================================
   125 				; loadDuckFrame
   126 				; Copies a 16-byte duck walk-cycle frame into Player 0's visible PM
   127 				; memory (PMBASE + $0200 + 16, combined here at assemble time since
   128 				; none of those three values change at runtime).
   129 				; ON ENTRY: spritePtr_lo/spritePtr_hi point at a 16-byte frame table
   130 				;           (duckShape1 or duckShape2)
   131 				; ON EXIT:  spritePtr_lo/spritePtr_hi have been walked forward by 16 —
   132 				;           reload them before calling again
   133 				;=========================================================================
   134 20A8			        .proc loadDuckFrame
   135 				 
   136 				        ; Target row = playfield top (PMBASE+$0200+16) + shipY.
   137 				        ; shipY=0 means "top of the visible screen" — the fixed
   138 				        ; +16 offset is baked into this proc so callers never need
   139 				        ; to think about PM memory layout, only screen position.
   140 20A8 A9 10		        lda #<(PMBASE+$0200+16)
   141 20AA 18			        clc
   142 20AB 65 B2		        adc shipY               ; no '#' — read the BYTE STORED at
   143 				                                 ; shipY, not the address itself
   144 20AD 85 85		        sta scrptr_lo
   145 				 
   146 20AF A9 52		        lda #>(PMBASE+$0200+16)
   147 20B1 69 00		        adc #0                  ; propagate any carry out of the low
   148 				                                 ; byte add above — do NOT clc here,
   149 				                                 ; we want to keep that carry
   150 20B3 85 86		        sta scrptr_hi
   151 				 
   152 20B5 A2 00		        ldx #0
   153 20B7			frameLoop:
   154 20B7 A0 00		        ldy #0
   155 20B9 B1 A6		        lda (spritePtr_lo),y
   156 20BB 91 85		        sta (scrptr_lo),y
   157 				 
   158 20BD E6 A6		        inc spritePtr_lo
   159 20BF D0 02		        bne spNoCarry
   160 20C1 E6 A7		        inc spritePtr_hi
   161 20C3			spNoCarry:
   162 20C3 E6 85		        inc scrptr_lo
   163 20C5 D0 02		        bne scNoCarry
   164 20C7 E6 86		        inc scrptr_hi
   165 20C9			scNoCarry:
   166 20C9 E8			        inx
   167 20CA E0 10		        cpx #16                  ; both frames MUST be 16 bytes for this
   168 20CC D0 E9		        bne frameLoop            ; fixed count to be safe
   169 				 
   170 20CE 60			        rts
   171 				        .endp
   172
   173
   174 				;=========================================================================
   175 				; eraseDuckFrame
   176 				; Zeroes 16 bytes at Player 0's CURRENT row (same address math as
   177 				; loadDuckFrame). Call this BEFORE shipY changes, so it clears where
   178 				; the duck IS, not where it's about to go — PM memory doesn't clear
   179 				; itself, so skipping this leaves a frozen duplicate duck behind
   180 				; every time you move vertically.
   181 				;=========================================================================
   182 20CF			        .proc eraseDuckFrame
   183
   184 20CF A9 10		        lda #<(PMBASE+$0200+16)
   185 20D1 18			        clc
   186 20D2 65 B2		        adc shipY
   187 20D4 85 85		        sta scrptr_lo
   188
   189 20D6 A9 52		        lda #>(PMBASE+$0200+16)
   190 20D8 69 00		        adc #0
   191 20DA 85 86		        sta scrptr_hi
   192
   193 20DC A2 00		        ldx #0
   194 20DE			eraseLoop:
   195 20DE A0 00		        ldy #0
   196 20E0 A9 00		        lda #0
   197 20E2 91 85		        sta (scrptr_lo),y
   198
   199 20E4 E6 85		        inc scrptr_lo
   200 20E6 D0 02		        bne eraseNoCarry
   201 20E8 E6 86		        inc scrptr_hi
   202 20EA			eraseNoCarry:
   203 20EA E8			        inx
   204 20EB E0 10		        cpx #16
   205 20ED D0 EF		        bne eraseLoop
   206
   207 20EF 60			        rts
   208 				        .endp
   209
