    18 				;=========================================================================
    19 				; initPMG
    20 				; Sets up Player-Missile Graphics hardware: clears the PM memory block,
    21 				; points ANTIC at it, and enables Player display via GRACTL and DMACTL.
    22 				; Must be called AFTER openGR8 (since it builds on top of the DMACTL
    23 				; value openGR8 already set, rather than overwriting it).
    24 				; ON ENTRY: nothing required
    25 				; ON EXIT:  PM memory cleared, hardware enabled, ready to load shapes
    26 				;=========================================================================
    27 3018			        .proc initPMG
    28
    29 				        ; Step 1: clear the entire PM memory block (5 pages = 1280 bytes)
    30 				        ; same nested-loop pattern as clearScreen, just a different
    31 				        ; base address and a different page count
    32 3018 A9 00 85 85		        mva #<PMBASE scrptr_lo
    33 301C A9 50 85 86		        mva #>PMBASE scrptr_hi
    34
    35 3020 A2 05		        ldx #5              ; X = 5 pages to clear (1280 bytes total)
    36 3022 A0 00		        ldy #0              ; Y = byte index within page
    37
    38 3024			clearPMpage:
    39 3024 A9 00		        lda #$00
    40 3026 91 85		        sta (scrptr_lo),y
    41 3028 C8			        iny
    42 3029 D0 F9		        bne clearPMpage     ; inner loop — 256 bytes per page
    43
    44 302B E6 86		        inc scrptr_hi       ; advance to next page
    45 302D CA			        dex
    46 302E D0 F4		        bne clearPMpage     ; outer loop — 5 pages
    47
    48 				        ; Step 2: tell ANTIC where PM memory starts
    49 				        ; ANTIC only needs the HIGH byte — PMBASE's low byte is
    50 				        ; guaranteed to be $00 since we required page alignment
    51 3030 A9 50		        lda #>PMBASE
    52 3032 8D 07 D4		        sta PMBASE_SHADOW
    53
    54 				        ; Step 3: enable Player display via GRACTL
    55 				        ; bit 1 = enable players, bit 0 = enable missiles
    56 				        ; we'll enable both even though we're only using Player 0
    57 				        ; for now, since it costs nothing extra
    58 3035 A9 03		        lda #%00000011
    59 3037 8D 1D D0		        sta GRACTL
    60
    61 				        ; Step 4: enable PM DMA — use the complete known-good value
    62 				        ; rather than guessing at individual bits
    63 303A A9 2E		        lda #PMG_DMACTL_VALUE
    64 303C 8D 2F 02		        sta SDMCTL
    65
    66 303F 60			        rts
    67 				        .endp
    68
    69
    70 				;=========================================================================================
    71 				; draw a sprite
    72 				; Assumptions: caller sets spritePtr_lo/spritePtr_hi 
    73 				;       (and presumably baseX_lo/baseX_hi/baseY) before calling
    74 				;
    75 				; spritePtr = address of shipSprite
    76 				; row = 0
    77 				; for byteIndex = 0 to 23:
    78 				;    spriteByte = read byte at spritePtr, advance spritePtr
    79 				;    columnBase = (byteIndex mod 2) * 8        ; 0 for even bytes, 8 for odd bytes
    80 				;    mask = %10000000
    81 				;    for bitCounter = 0 to 7:
    82 				;        if spriteByte AND mask != 0:
    83 				;            plotX = baseX + columnBase + bitCounter
    84 				;            plotY = baseY + row
    85 				;            plotPoint
    86 				;        mask = mask >> 1
    87 				;    if byteIndex is odd:
    88 				;        row = row + 1
    89 3040			.proc drawSprite
    90
    91 3040 A5 A6		        lda spritePtr_lo
    92 3042 48			        pha
    93 3043 A5 A7		        lda spritePtr_hi
    94 3045 48			        pha
    95
    96 3046 A9 00 85 AA		        mva #0 spriteRow
    97 304A A9 00 85 AC		        mva #0 byteCount
    98 304E A9 00 85 AB		        mva #0 columnBase
    99
   100 3052			spriteloop:
   101 3052 A0 00		        ldy #0
   102 3054 B1 A6		        lda (spritePtr_lo),y
   103 3056 85 A8		        sta spriteByte
   104
   105 3058 A9 80 85 A9		        mva #%10000000 spriteMask
   106 305C A9 00 85 B0		        mva #0 bitCounter
   107
   108 3060			bittest:
   109 3060 A5 A8		        lda spriteByte
   110 3062 25 A9		        and spriteMask
   111 3064 F0 1A		        beq skipbit
   112
   113 3066 A5 AD		        lda baseX_lo
   114 3068 18			        clc
   115 3069 65 AB		        adc columnBase
   116 306B 18			        clc
   117 306C 65 B0		        adc bitCounter
   118 306E 85 80		        sta plotX_lo
   119 3070 A5 AE		        lda baseX_hi
   120 3072 69 00		        adc #0
   121 3074 85 81		        sta plotX_hi
   122
   123 3076 A5 AF		        lda baseY
   124 3078 18			        clc
   125 3079 65 AA		        adc spriteRow
   126 307B 85 82		        sta plotY
   127
   128 307D 20 8B 35		        jsr plotPoint
   129
   130 3080			skipbit:
   131 3080 46 A9		        lsr spriteMask
   132 3082 E6 B0		        inc bitCounter
   133 3084 A5 B0		        lda bitCounter
   134 3086 C9 08		        cmp #8
   135 3088 D0 D6		        bne bittest
   136
   137 308A E6 A6		        inc spritePtr_lo
   138 308C D0 02		        bne noCarry
   139 308E E6 A7		        inc spritePtr_hi
   140 3090			noCarry:
   141 3090 A5 AB		        lda columnBase
   142 3092 F0 09		        beq setTo8
   143 3094 A9 00 85 AB		        mva #0 columnBase
   144 3098 E6 AA		        inc spriteRow
   145 309A 4C A1 30		        jmp afterToggle
   146 309D			setTo8:
   147 309D A9 08 85 AB		        mva #8 columnBase
   148 30A1			afterToggle:
   149
   150 30A1 E6 AC		        inc byteCount
   151 30A3 A5 AC		        lda byteCount
   152 30A5 C9 18		        cmp #24
   153 30A7 D0 A9		        bne spriteloop
   154
   155 30A9 68			        pla
   156 30AA 85 A7		        sta spritePtr_hi
   157 30AC 68			        pla
   158 30AD 85 A6		        sta spritePtr_lo
   159
   160 30AF 60			        rts
   161 				        .endp
   162
   163
   164
   165 				;=========================================================================
   166 				; drawSpriteSolo - Preserved for all the great comments.
   167 				;
   168 				; Draws a 16-pixel-wide, 12-row-tall sprite (the spaceship "Beowulf")
   169 				; from a packed bitmap table in memory, onto the GR.8 screen.
   170 				;
   171 				; The sprite data is stored as 24 bytes total: each row of the sprite
   172 				; is 16 pixels wide, which needs 2 bytes per row (8 bits per byte),
   173 				; and there are 12 rows, so 2 bytes × 12 rows = 24 bytes.
   174 				;
   175 				; ON ENTRY: spritePtr_lo/spritePtr_hi point to the start of the sprite
   176 				;           bitmap data (24 consecutive bytes)
   177 				;           baseX_lo/baseX_hi = screen X coordinate of the sprite's
   178 				;           top-left corner (16-bit, since X can go up to 319)
   179 				;           baseY = screen Y coordinate of the sprite's top-left corner
   180 				; ON EXIT:  every "1" bit in the sprite data has been plotted as a
   181 				;           pixel on screen at the correct offset from (baseX, baseY)
   182 				;=========================================================================
   183 30B0			        .proc drawSpriteSolo
   184
   185 30B0 A9 00 85 AA		        mva #0 spriteRow       ; spriteRow = 0 — tracks which row of the
   186 				                                ; sprite (0-11) we're currently drawing
   187 30B4 A9 00 85 AC		        mva #0 byteCount       ; byteCount = 0 — tracks how many of the
   188 				                                ; 24 total sprite bytes we've processed
   189 30B8 A9 00 85 AB		        mva #0 columnBase      ; columnBase = 0 — tracks whether we're in
   190 				                                ; the LEFT half (0-7) or RIGHT half (8-15)
   191 				                                ; of the current row, since each row needs
   192 				                                ; two bytes (left byte then right byte)
   193
   194 				;-------------------------------------------------------------------------
   195 				; Outer loop: process one byte of sprite data per pass.
   196 				; Each byte represents 8 horizontal pixels (1 bit = 1 pixel).
   197 				;-------------------------------------------------------------------------
   198 30BC			spriteloop:
   199 30BC A0 00		        ldy #0                          ; Y = 0 (offset for indirect read)
   200 30BE B1 A6		        lda (spritePtr_lo),y             ; A = memory[spritePtr + Y]
   201 				                                        ; fetch the current sprite byte
   202 				                                        ; using our 16-bit pointer
   203 30C0 85 A8		        sta spriteByte                  ; save it — we'll be testing each
   204 				                                        ; bit of it one at a time below
   205
   206 30C2 A9 80 85 A9		        mva #%10000000 spriteMask       ; spriteMask = %10000000
   207 				                                        ; start by testing the LEFTMOST
   208 				                                        ; bit (bit 7) of this byte first
   209 30C6 A9 00 85 B0		        mva #0 bitCounter               ; bitCounter = 0 — tracks which of
   210 				                                        ; the 8 bits within this byte
   211 				                                        ; we're currently testing (0-7)
   212
   213 				;-------------------------------------------------------------------------
   214 				; Inner loop: test each of the 8 bits in the current sprite byte.
   215 				; If a bit is "1" we plot a pixel there; if "0" we skip it (background).
   216 				;-------------------------------------------------------------------------
   217 30CA			bittest:
   218 30CA A5 A8		        lda spriteByte                  ; A = the sprite byte we saved
   219 30CC 25 A9		        and spriteMask                  ; A = A AND spriteMask
   220 				                                        ; isolates just the one bit we
   221 				                                        ; care about this pass — result
   222 				                                        ; is 0 if that bit was clear,
   223 				                                        ; non-zero if that bit was set
   224 30CE F0 1A		        beq skipbit                     ; if the bit was 0 (background),
   225 				                                        ; skip plotting and move on
   226
   227 				        ; --- this bit is "1" — calculate where on screen it belongs ---
   228
   229 				        ; plotX = baseX + columnBase + bitCounter  (16-bit safe addition)
   230 				        ; columnBase shifts us into the left (0) or right (8) half of
   231 				        ; the row, and bitCounter adds the specific pixel offset (0-7)
   232 				        ; within that half — together they give the pixel's column
   233 				        ; position relative to the sprite's top-left corner.
   234 30D0 A5 AD		        lda baseX_lo                    ; A = low byte of sprite's base X
   235 30D2 18			        clc                             ; clear carry before first add
   236 30D3 65 AB		        adc columnBase                  ; A += columnBase (0 or 8)
   237 30D5 18			        clc                             ; clear carry again — columnBase
   238 				                                        ; and bitCounter are both small
   239 				                                        ; values (0-15) so we re-clear
   240 				                                        ; to be explicit/safe before the
   241 				                                        ; second addition
   242 30D6 65 B0		        adc bitCounter                  ; A += bitCounter (0-7)
   243 30D8 85 80		        sta plotX_lo                    ; plotX_lo = final low byte
   244 30DA A5 AE		        lda baseX_hi                    ; A = high byte of sprite's base X
   245 30DC 69 00		        adc #0                          ; propagate any carry from the
   246 				                                        ; low byte additions above into
   247 				                                        ; the high byte (16-bit safe)
   248 30DE 85 81		        sta plotX_hi                    ; plotX_hi = final high byte
   249
   250 				        ; plotY = baseY + spriteRow
   251 				        ; simple 8-bit addition since Y only ranges 0-191 on screen
   252 30E0 A5 AF		        lda baseY                       ; A = sprite's base Y coordinate
   253 30E2 18			        clc                             ; clear carry before adding
   254 30E3 65 AA		        adc spriteRow                   ; A += spriteRow (0-11)
   255 30E5 85 82		        sta plotY                       ; plotY = final row position
   256
   257 				        ; plotPoint destroys plotX_lo/plotX_hi during its internal
   258 				        ; division — but we don't need those values again until we
   259 				        ; recalculate them fresh on the next bit, so no save/restore
   260 				        ; is needed here (unlike in drawLine where we reused plotX
   261 				        ; across iterations without recalculating it each time)
   262 30E7 20 8B 35		        jsr plotPoint                   ; plot this single pixel!
   263
   264 30EA			skipbit:
   265 30EA 46 A9		        lsr spriteMask                  ; shift the mask right one
   266 				                                        ; position — moves us from
   267 				                                        ; testing bit 7 down to bit 6,
   268 				                                        ; then bit 5, etc. on later passes
   269 30EC E6 B0		        inc bitCounter                  ; bitCounter++ — advance to the
   270 				                                        ; next pixel position (0 through 7)
   271 30EE A5 B0		        lda bitCounter
   272 30F0 C9 08		        cmp #8                          ; have we tested all 8 bits in
   273 				                                        ; this byte yet?
   274 30F2 D0 D6		        bne bittest                     ; no — go test the next bit
   275
   276 				;-------------------------------------------------------------------------
   277 				; Finished all 8 bits of the current byte. Advance to the next byte
   278 				; in the sprite data, and figure out whether that next byte is the
   279 				; right half of the SAME row, or the left half of the NEXT row.
   280 				;-------------------------------------------------------------------------
   281
   282 				        ; advance the 16-bit sprite data pointer to the next byte
   283 30F4 E6 A6		        inc spritePtr_lo
   284 30F6 D0 02		        bne noCarry                     ; if low byte didn't wrap to 0,
   285 				                                        ; no need to touch the high byte
   286 30F8 E6 A7		        inc spritePtr_hi                ; low byte wrapped — carry into
   287 				                                        ; the high byte (16-bit increment)
   288 30FA			noCarry:
   289 				        ; columnBase toggles between 0 and 8 each time we finish a byte.
   290 				        ; Since each row is 16 pixels wide but each byte only covers 8
   291 				        ; pixels, every row needs exactly TWO bytes: one for columns
   292 				        ; 0-7 (columnBase=0) and one for columns 8-15 (columnBase=8).
   293 30FA A5 AB		        lda columnBase
   294 30FC F0 09		        beq setTo8                      ; if columnBase was 0 (we just
   295 				                                        ; finished the LEFT half), switch
   296 				                                        ; to 8 for the RIGHT half next
   297 				        ; columnBase was 8 — we just finished the RIGHT half of a row,
   298 				        ; meaning the entire row (both bytes) is now complete.
   299 30FE A9 00 85 AB		        mva #0 columnBase                ; reset columnBase back to 0
   300 				                                        ; for the start of the next row
   301 3102 E6 AA		        inc spriteRow                   ; spriteRow++ — move down to the
   302 				                                        ; next row of the sprite
   303 3104 4C 0B 31		        jmp afterToggle
   304 3107			setTo8:
   305 3107 A9 08 85 AB		        mva #8 columnBase                ; switch to the right half (8-15)
   306 				                                        ; of the CURRENT row — spriteRow
   307 				                                        ; does NOT increment here since
   308 				                                        ; we're still on the same row
   309 310B			afterToggle:
   310
   311 310B E6 AC		        inc byteCount                    ; byteCount++ — one more of the
   312 				                                        ; 24 total sprite bytes processed
   313 310D A5 AC		        lda byteCount
   314 310F C9 18		        cmp #24                          ; have we processed all 24 bytes
   315 				                                        ; (2 bytes × 12 rows) yet?
   316 3111 D0 A9		        bne spriteloop                   ; no — go process the next byte
   317
   318 3113 60			        rts                              ; yes — the entire sprite has
   319 				                                        ; been drawn, return to caller
   320 				        .endp
   321
   322 				;=========================================================================================
   323 3114			.proc eraseSprite
   324
   325 				        ; save the caller's original spritePtr — see drawSprite for
   326 				        ; why this matters (pointer would otherwise drift forward
   327 				        ; by 24 bytes every call)
   328 3114 A5 A6		        lda spritePtr_lo
   329 3116 48			        pha
   330 3117 A5 A7		        lda spritePtr_hi
   331 3119 48			        pha
   332
   333 311A A9 00 85 AA		        mva #0 spriteRow
   334 311E A9 00 85 AC		        mva #0 byteCount
   335 3122 A9 00 85 AB		        mva #0 columnBase
   336
   337 3126			eraseloop:
   338 3126 A0 00		        ldy #0
   339 3128 B1 A6		        lda (spritePtr_lo),y
   340 312A 85 A8		        sta spriteByte
   341
   342 312C A9 80 85 A9		        mva #%10000000 spriteMask
   343 3130 A9 00 85 B0		        mva #0 bitCounter
   344
   345 3134			erasebittest:
   346 3134 A5 A8		        lda spriteByte
   347 3136 25 A9		        and spriteMask
   348 3138 F0 1A		        beq eraseskipbit
   349
   350 313A A5 AD		        lda baseX_lo
   351 313C 18			        clc
   352 313D 65 AB		        adc columnBase
   353 313F 18			        clc
   354 3140 65 B0		        adc bitCounter
   355 3142 85 80		        sta plotX_lo
   356 3144 A5 AE		        lda baseX_hi
   357 3146 69 00		        adc #0
   358 3148 85 81		        sta plotX_hi
   359
   360 314A A5 AF		        lda baseY
   361 314C 18			        clc
   362 314D 65 AA		        adc spriteRow
   363 314F 85 82		        sta plotY
   364
   365 3151 20 84 31		        jsr erasePoint
   366
   367 3154			eraseskipbit:
   368 3154 46 A9		        lsr spriteMask
   369 3156 E6 B0		        inc bitCounter
   370 3158 A5 B0		        lda bitCounter
   371 315A C9 08		        cmp #8
   372 315C D0 D6		        bne erasebittest
   373
   374 315E E6 A6		        inc spritePtr_lo
   375 3160 D0 02		        bne eraseNoCarry
   376 3162 E6 A7		        inc spritePtr_hi
   377 3164			eraseNoCarry:
   378 3164 A5 AB		        lda columnBase
   379 3166 F0 09		        beq eraseSetTo8
   380 3168 A9 00 85 AB		        mva #0 columnBase
   381 316C E6 AA		        inc spriteRow
   382 316E 4C 75 31		        jmp eraseAfterToggle
   383 3171			eraseSetTo8:
   384 3171 A9 08 85 AB		        mva #8 columnBase
   385 3175			eraseAfterToggle:
   386
   387 3175 E6 AC		        inc byteCount
   388 3177 A5 AC		        lda byteCount
   389 3179 C9 18		        cmp #24
   390 317B D0 A9		        bne eraseloop
   391
   392 				        ; restore spritePtr to its starting value before returning
   393 317D 68			        pla
   394 317E 85 A7		        sta spritePtr_hi
   395 3180 68			        pla
   396 3181 85 A6		        sta spritePtr_lo
   397
   398 3183 60			        rts
   399 				        .endp
   400
   401
   402 				;=========================================================================
   403 				; erasePoint
   404 				; Clears (turns OFF) a single pixel in GR.8 screen RAM, at the position
   405 				; given by plotX_lo/plotX_hi and plotY. This is the exact mirror of
   406 				; plotPoint — same six steps to locate the byte and bit — except the
   407 				; final step CLEARS the bit instead of SETTING it.
   408 				; ON ENTRY: plotX_lo/plotX_hi/plotY contain the pixel coordinates
   409 				; ON EXIT:  the corresponding screen RAM bit is cleared to 0 (background)
   410 				;           NOTE: just like plotPoint, this destroys plotX_lo/plotX_hi!
   411 				;=========================================================================
   412 3184			        .proc erasePoint
   413
   414 				        ; defeat attract mode on every erase, same as plotPoint does
   415 3184 A9 00 85 4D		        mva #0    ATRACT
   416 3188 A9 FF 85 4E		        mva #$FF  ATRMSK
   417
   418 				        ; Step 1: Find which ROW we're on  (plotY × 40)
   419 318C A5 82		        lda plotY
   420 318E 85 83		        sta temp_lo
   421 3190 A9 00		        lda #0
   422 3192 85 84		        sta temp_hi
   423
   424 3194 06 83		        asl temp_lo
   425 3196 26 84		        rol temp_hi
   426
   427 3198 06 83		        asl temp_lo
   428 319A 26 84		        rol temp_hi
   429
   430 319C 06 83		        asl temp_lo
   431 319E 26 84		        rol temp_hi
   432 31A0 A5 83		        lda temp_lo
   433 31A2 85 87		        sta save_lo
   434 31A4 A5 84		        lda temp_hi
   435 31A6 85 88		        sta save_hi
   436
   437 31A8 06 83		        asl temp_lo
   438 31AA 26 84		        rol temp_hi
   439
   440 31AC 06 83		        asl temp_lo
   441 31AE 26 84		        rol temp_hi
   442
   443 31B0 A5 83		        lda temp_lo
   444 31B2 18			        clc
   445 31B3 65 87		        adc save_lo
   446 31B5 85 83		        sta temp_lo
   447
   448 31B7 A5 84		        lda temp_hi
   449 31B9 65 88		        adc save_hi
   450 31BB 85 84		        sta temp_hi
   451
   452 				        ; calculate which bit (plotX mod 8)
   453 31BD A5 80		        lda plotX_lo
   454 31BF 29 07		        and #%00000111
   455 31C1 85 89		        sta bitpos
   456
   457 				        ; Step 2: plotX ÷ 8 using 16-bit right shift
   458 31C3 46 81		        lsr plotX_hi
   459 31C5 66 80		        ror plotX_lo
   460
   461 31C7 46 81		        lsr plotX_hi
   462 31C9 66 80		        ror plotX_lo
   463
   464 31CB 46 81		        lsr plotX_hi
   465 31CD 66 80		        ror plotX_lo
   466
   467 				        ; Step 3: add row offset + column offset
   468 31CF A5 83		        lda temp_lo
   469 31D1 18			        clc
   470 31D2 65 80		        adc plotX_lo
   471 31D4 85 83		        sta temp_lo
   472
   473 31D6 A5 84		        lda temp_hi
   474 31D8 69 00		        adc #0
   475 31DA 85 84		        sta temp_hi
   476
   477 				        ; Step 4: Add SAVMSC Base Address
   478 31DC A5 83		        lda temp_lo
   479 31DE 18			        clc
   480 31DF 65 58		        adc SAVMSC
   481 31E1 85 85		        sta scrptr_lo
   482
   483 31E3 A5 84		        lda temp_hi
   484 31E5 65 59		        adc SAVMSC+1
   485 31E7 85 86		        sta scrptr_hi
   486
   487 				        ; Step 5: find which bit to turn off
   488 31E9 A9 80		        lda #$80
   489 31EB A6 89		        ldx bitpos
   490 31ED F0 04		        beq done_shift
   491 31EF			shift_loop_erase:
   492 31EF 4A			        lsr
   493 31F0 CA			        dex
   494 31F1 D0 FC		        bne shift_loop_erase
   495 31F3			done_shift:
   496
   497 				        ; Step 6: turn OFF our bit (the only step that differs from
   498 				        ; plotPoint!) — invert the mask so every bit is 1 EXCEPT
   499 				        ; our target pixel, then AND it against the screen byte to
   500 				        ; clear just that one bit while leaving all others untouched
   501 31F3 49 FF		        eor #$FF                ; invert: our bit is now 0, rest are 1
   502 31F5 85 8A		        sta bitmask              ; save the inverted mask
   503 31F7 A0 00		        ldy #0
   504 31F9 B1 85		        lda (scrptr_lo),y        ; read current byte from screen RAM
   505 31FB 25 8A		        and bitmask               ; AND clears just our bit
   506 31FD 91 85		        sta (scrptr_lo),y        ; write modified byte back
   507
   508 31FF 60			        rts
   509 				        .endp
   510
   511 				;=========================================================================
   512 				; waitFrames
   513 				; Pauses execution for a given number of vertical blank frames.
   514 				; On PAL the frame counter at $14 increments roughly 50 times per
   515 				; second; on NTSC it's roughly 60 times per second. The OS updates
   516 				; this counter automatically during every VBI, completely independent
   517 				; of our code — so we just watch it change.
   518 				; ON ENTRY: X contains the number of frames to wait
   519 				; ON EXIT:  approximately X/50 seconds (PAL) have elapsed
   520 				;=========================================================================
   521 3200			        .proc waitFrames
   522
   523 3200			waitOneFrame:
   524 3200 A5 14		        lda $14
   525 3202			holdFrame:
   526 3202 C5 14		        cmp $14
   527 3204 F0 FC		        beq holdFrame
   528
   529 				        ; re-assert PMG hardware state every frame while waiting,
   530 				        ; in case whatever caused tonight's display dropout is
   531 				        ; tied to extended periods without any register refresh
   532 3206 A5 B1		        lda shipX
   533 3208 8D 00 D0		        sta HPOSP0
   534 320B A9 1E		        lda #$1E
   535 320D 8D 12 D0		        sta COLPM0
   536
   537 3210 CA			        dex
   538 3211 D0 ED		        bne waitOneFrame
   539
   540 3213 60			        rts
   541 				        .endp
   542
   543
   544
   545 				;=========================================================================================
   546 				; draw a circle using Bresenham's circle algorithm
   547 				; ON ENTRY: cx/cx_hi = center X, cy = center Y, radius = radius
   548 				; ON EXIT:  circle drawn on screen
   549
   550 3214			        .proc drawCircle
   551
   552 				        ; initialize error term: cerr = 1 - radius
   553 3214 A9 01		        lda #1
   554 3216 38			        sec
   555 3217 E5 9E		        sbc radius
   556 3219 85 A1		        sta cerr_lo
   557 321B A9 00		        lda #0
   558 321D E9 00		        sbc #0
   559 321F 85 A2		        sta cerr_hi
   560
   561 				        ; initialize offsets
   562 3221 A9 00 85 9F		        mva #0  circX       ; circX = 0
   563 3225 A5 9E		        lda radius
   564 3227 85 A0		        sta circY           ; circY = radius
   565
   566 3229			circleloop:
   567
   568 				        ; plot point 1: (cx + circX, cy + circY)
   569 3229 A5 9B		        lda cx
   570 322B 18			        clc
   571 322C 65 9F		        adc circX
   572 322E 85 80		        sta plotX_lo
   573 3230 A5 9C		        lda cx_hi
   574 3232 69 00		        adc #0
   575 3234 85 81		        sta plotX_hi
   576 3236 A5 9D		        lda cy
   577 3238 18			        clc
   578 3239 65 A0		        adc circY
   579 323B 85 82		        sta plotY
   580
   581 323D A5 80		        lda plotX_lo
   582 323F 48			        pha
   583 3240 A5 81		        lda plotX_hi
   584 3242 48			        pha
   585 3243 20 8B 35		        jsr plotPoint
   586 3246 68			        pla
   587 3247 85 81		        sta plotX_hi
   588 3249 68			        pla
   589 324A 85 80		        sta plotX_lo
   590
   591 				        ; plot point 2: (cx - circX, cy + circY)
   592 324C A5 9B		        lda cx
   593 324E 38			        sec
   594 324F E5 9F		        sbc circX
   595 3251 85 80		        sta plotX_lo
   596 3253 A5 9C		        lda cx_hi
   597 3255 E9 00		        sbc #0
   598 3257 85 81		        sta plotX_hi
   599 3259 A5 9D		        lda cy
   600 325B 18			        clc
   601 325C 65 A0		        adc circY
   602 325E 85 82		        sta plotY
   603
   604 3260 A5 80		        lda plotX_lo
   605 3262 48			        pha
   606 3263 A5 81		        lda plotX_hi
   607 3265 48			        pha
   608 3266 20 8B 35		        jsr plotPoint
   609 3269 68			        pla
   610 326A 85 81		        sta plotX_hi
   611 326C 68			        pla
   612 326D 85 80		        sta plotX_lo
   613
   614 				        ; plot point 3: (cx + circX, cy - circY)
   615 326F A5 9B		        lda cx
   616 3271 18			        clc
   617 3272 65 9F		        adc circX
   618 3274 85 80		        sta plotX_lo
   619 3276 A5 9C		        lda cx_hi
   620 3278 69 00		        adc #0
   621 327A 85 81		        sta plotX_hi
   622 327C A5 9D		        lda cy
   623 327E 38			        sec
   624 327F E5 A0		        sbc circY
   625 3281 85 82		        sta plotY
   626
   627 3283 A5 80		        lda plotX_lo
   628 3285 48			        pha
   629 3286 A5 81		        lda plotX_hi
   630 3288 48			        pha
   631 3289 20 8B 35		        jsr plotPoint
   632 328C 68			        pla
   633 328D 85 81		        sta plotX_hi
   634 328F 68			        pla
   635 3290 85 80		        sta plotX_lo
   636
   637 				        ; plot point 4: (cx - circX, cy - circY)
   638 3292 A5 9B		        lda cx
   639 3294 38			        sec
   640 3295 E5 9F		        sbc circX
   641 3297 85 80		        sta plotX_lo
   642 3299 A5 9C		        lda cx_hi
   643 329B E9 00		        sbc #0
   644 329D 85 81		        sta plotX_hi
   645 329F A5 9D		        lda cy
   646 32A1 38			        sec
   647 32A2 E5 A0		        sbc circY
   648 32A4 85 82		        sta plotY
   649
   650 32A6 A5 80		        lda plotX_lo
   651 32A8 48			        pha
   652 32A9 A5 81		        lda plotX_hi
   653 32AB 48			        pha
   654 32AC 20 8B 35		        jsr plotPoint
   655 32AF 68			        pla
   656 32B0 85 81		        sta plotX_hi
   657 32B2 68			        pla
   658 32B3 85 80		        sta plotX_lo
   659
   660 				        ; plot point 5: (cx + circY, cy + circX)
   661 32B5 A5 9B		        lda cx
   662 32B7 18			        clc
   663 32B8 65 A0		        adc circY
   664 32BA 85 80		        sta plotX_lo
   665 32BC A5 9C		        lda cx_hi
   666 32BE 69 00		        adc #0
   667 32C0 85 81		        sta plotX_hi
   668 32C2 A5 9D		        lda cy
   669 32C4 18			        clc
   670 32C5 65 9F		        adc circX
   671 32C7 85 82		        sta plotY
   672
   673 32C9 A5 80		        lda plotX_lo
   674 32CB 48			        pha
   675 32CC A5 81		        lda plotX_hi
   676 32CE 48			        pha
   677 32CF 20 8B 35		        jsr plotPoint
   678 32D2 68			        pla
   679 32D3 85 81		        sta plotX_hi
   680 32D5 68			        pla
   681 32D6 85 80		        sta plotX_lo
   682
   683 				        ; plot point 6: (cx - circY, cy + circX)
   684 32D8 A5 9B		        lda cx
   685 32DA 38			        sec
   686 32DB E5 A0		        sbc circY
   687 32DD 85 80		        sta plotX_lo
   688 32DF A5 9C		        lda cx_hi
   689 32E1 E9 00		        sbc #0
   690 32E3 85 81		        sta plotX_hi
   691 32E5 A5 9D		        lda cy
   692 32E7 18			        clc
   693 32E8 65 9F		        adc circX
   694 32EA 85 82		        sta plotY
   695
   696 32EC A5 80		        lda plotX_lo
   697 32EE 48			        pha
   698 32EF A5 81		        lda plotX_hi
   699 32F1 48			        pha
   700 32F2 20 8B 35		        jsr plotPoint
   701 32F5 68			        pla
   702 32F6 85 81		        sta plotX_hi
   703 32F8 68			        pla
   704 32F9 85 80		        sta plotX_lo
   705
   706 				        ; plot point 7: (cx + circY, cy - circX)
   707 32FB A5 9B		        lda cx
   708 32FD 18			        clc
   709 32FE 65 A0		        adc circY
   710 3300 85 80		        sta plotX_lo
   711 3302 A5 9C		        lda cx_hi
   712 3304 69 00		        adc #0
   713 3306 85 81		        sta plotX_hi
   714 3308 A5 9D		        lda cy
   715 330A 38			        sec
   716 330B E5 9F		        sbc circX
   717 330D 85 82		        sta plotY
   718
   719 330F A5 80		        lda plotX_lo
   720 3311 48			        pha
   721 3312 A5 81		        lda plotX_hi
   722 3314 48			        pha
   723 3315 20 8B 35		        jsr plotPoint
   724 3318 68			        pla
   725 3319 85 81		        sta plotX_hi
   726 331B 68			        pla
   727 331C 85 80		        sta plotX_lo
   728
   729 				        ; plot point 8: (cx - circY, cy - circX)
   730 331E A5 9B		        lda cx
   731 3320 38			        sec
   732 3321 E5 A0		        sbc circY
   733 3323 85 80		        sta plotX_lo
   734 3325 A5 9C		        lda cx_hi
   735 3327 E9 00		        sbc #0
   736 3329 85 81		        sta plotX_hi
   737 332B A5 9D		        lda cy
   738 332D 38			        sec
   739 332E E5 9F		        sbc circX
   740 3330 85 82		        sta plotY
   741
   742 3332 A5 80		        lda plotX_lo
   743 3334 48			        pha
   744 3335 A5 81		        lda plotX_hi
   745 3337 48			        pha
   746 3338 20 8B 35		        jsr plotPoint
   747 333B 68			        pla
   748 333C 85 81		        sta plotX_hi
   749 333E 68			        pla
   750 333F 85 80		        sta plotX_lo
   751
   752 				        ; advance circX
   753 3341 E6 9F		        inc circX
   754
   755 				        ; check sign of cerr
   756 3343 A5 A2		        lda cerr_hi
   757 3345 30 19		        bmi update_negative     ; cerr < 0
   758
   759 				        ; positive path: cerr >= 0
   760 3347 C6 A0		        dec circY               ; circY = circY - 1
   761 3349 A5 9F		        lda circX
   762 334B 38			        sec
   763 334C E5 A0		        sbc circY               ; A = circX - circY
   764 334E 0A			        asl                     ; A = 2*(circX-circY)
   765 334F 18			        clc
   766 3350 69 01		        adc #1                  ; A = 2*(circX-circY) + 1
   767 3352 18			        clc
   768 3353 65 A1		        adc cerr_lo
   769 3355 85 A1		        sta cerr_lo
   770 3357 A5 A2		        lda cerr_hi
   771 3359 69 00		        adc #0
   772 335B 85 A2		        sta cerr_hi
   773 335D 4C 71 33		        jmp check_done          ; skip negative path
   774
   775 3360			update_negative:
   776 				        ; negative path: cerr < 0
   777 3360 A5 9F		        lda circX
   778 3362 0A			        asl                     ; A = 2*circX
   779 3363 18			        clc
   780 3364 69 01		        adc #1                  ; A = 2*circX + 1
   781 3366 18			        clc
   782 3367 65 A1		        adc cerr_lo
   783 3369 85 A1		        sta cerr_lo
   784 336B A5 A2		        lda cerr_hi
   785 336D 69 00		        adc #0
   786 336F 85 A2		        sta cerr_hi
   787 				                                ; fall through to check_done
   788
   789 3371			check_done:
   790 3371 A5 9F		        lda circX
   791 3373 C5 A0		        cmp circY
   792 3375 90 03		        bcc keep_going      ; circX < circY — short forward branch
   793 3377 F0 01		        beq keep_going      ; circX = circY — short forward branch
   794 3379 60			        rts                 ; circX > circY — done!
   795 337A			keep_going:
   796 337A 4C 29 32		        jmp circleloop      ; jump back — unlimited range
   797 				        .endp
   798
